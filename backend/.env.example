# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=felona
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT — generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_random_64_char_string
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_random_64_char_string
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (Gmail App Password — https://support.google.com/accounts/answer/185833)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# AI (Google Gemini — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — comma-separated allowed origins (leave empty for development)
# CORS_ORIGINS=https://your-app.com,https://www.your-app.com
